{
  "manifest_version": 3,
  "name": "Atlas Job Assistant",
  "version": "1.0.0",
  "description": "Scan and apply to Naukri jobs from your preferences, synced to Atlas",
  "permissions": ["storage", "alarms", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Atlas"
  },
  "content_scripts": [
    {
      "matches": ["https://www.naukri.com/*", "https://naukri.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
