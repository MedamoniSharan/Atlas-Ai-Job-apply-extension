{
  "manifest_version": 3,
  "name": "Tsenta Job Assistant",
  "version": "1.0.0",
  "description": "Scan and apply to Naukri jobs from your preferences, synced to Tsenta",
  "permissions": ["storage", "alarms", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:4000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tsenta"
  },
  "content_scripts": [
    {
      "matches": ["https://www.naukri.com/*", "https://naukri.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["webBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
